#!/usr/bin/env just --justfile

set dotenv-load := true

_default:
    just --list

# Clean up the build artifacts
clean:
    cargo clean
    rm -rf ffi/python/dist ffi/python/build

# Run cargo check on the project
check:
    cargo check --manifest-path Cargo.toml --workspace --all-targets --all-features

# Run cargo check without default features
check-no-default-features:
    cargo check --manifest-path Cargo.toml --workspace --no-default-features

# Run cargo check for the optional Parquet feature
check-parquet:
    cargo check --manifest-path Cargo.toml --workspace --features parquet

# Build the project
build *args:
    cargo build --manifest-path Cargo.toml --workspace --all-targets --all-features {{args}}

# Run cargo clippy on the project
lint:
    cargo clippy --manifest-path Cargo.toml --workspace --all-targets --all-features -- -Dclippy::all -Dclippy::pedantic -Aclippy::float_cmp

# Run cargo fmt on the project
fmt:
    cargo fmt --manifest-path Cargo.toml
    cargo fmt --manifest-path ffi/core/Cargo.toml
    cargo fmt --manifest-path ffi/wasm/Cargo.toml

# Run cargo test on the project
test:
    cargo test --manifest-path Cargo.toml --workspace

# Run cargo test with all features enabled
test-all-features:
    cargo test --manifest-path Cargo.toml --workspace --all-features

# Build the docs
docs-build:
    uv run properdocs build

# Serve the docs locally
docs-serve *args:
    uv run properdocs serve -o {{args}}

# Run fmt, lint, check, test, perf-check, and doc
ci:
    just fmt
    just lint
    just check-no-default-features
    just check-parquet
    just check
    just perf check
    just test
    just test-all-features
    just docs-build

perf *args:
    ./tools/perf.sh {{args}}

ffi-check:
    cargo check -p cityjson-lib-ffi-core -p cityjson-lib-wasm --all-targets
    python3 -m compileall -q ffi/python/src

ffi-build *args:
    cargo build -p cityjson-lib-ffi-core -p cityjson-lib-wasm --all-targets {{args}}

ffi-test:
    cargo test -p cityjson-lib-ffi-core -p cityjson-lib-wasm
    PYTHONPATH=ffi/python/src python3 -m unittest ffi/python/tests/test_api.py
    cmake -S ffi/cpp -B target/ffi-cpp-build
    cmake --build target/ffi-cpp-build
    ctest --test-dir target/ffi-cpp-build --output-on-failure

ffi-doc:
    cargo doc -p cityjson-lib-ffi-core -p cityjson-lib-wasm --no-deps

ffi-header:
    mkdir -p ffi/core/include/cityjson_lib
    cbindgen --config ffi/core/cbindgen.toml --crate cityjson_lib_ffi_core --output ffi/core/include/cityjson_lib/cityjson_lib.h

build-python:
    uv build ffi/python/ --wheel --out-dir ffi/python/dist
