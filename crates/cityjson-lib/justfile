#!/usr/bin/env just --justfile

default:
    just --list

check:
    cargo check --workspace --all-targets --all-features

build *args:
    cargo build --workspace --all-targets --all-features {{args}}

lint:
    cargo clippy --workspace --all-targets --all-features -- -Dclippy::all -Dclippy::pedantic -Aclippy::float_cmp

fmt:
    cargo fmt --all

test:
    cargo test --workspace

doc:
    cargo doc --workspace --all-features --no-deps

ffi-check:
    cargo check -p cjlib-ffi-core -p cjlib-wasm --all-targets

ffi-build *args:
    cargo build -p cjlib-ffi-core -p cjlib-wasm --all-targets {{args}}

ffi-test:
    cargo test -p cjlib-ffi-core -p cjlib-wasm

ffi-doc:
    cargo doc -p cjlib-ffi-core -p cjlib-wasm --no-deps

ffi-header:
    mkdir -p ffi/core/include/cjlib
    cbindgen --config ffi/core/cbindgen.toml --crate cjlib-ffi-core --output ffi/core/include/cjlib/cjlib.h

docs-build:
    uv run --with-requirements python-requirements-dev.txt mkdocs build --strict

docs-serve *args:
    uv run --with-requirements python-requirements-dev.txt mkdocs serve {{args}}
