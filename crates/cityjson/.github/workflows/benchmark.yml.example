name: Benchmark

# This is an example CI/CD workflow for benchmarking
# Rename to benchmark.yml and customize as needed

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]
  # Allow manual triggers
  workflow_dispatch:

jobs:
  benchmark:
    name: Run Benchmarks
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Install Rust
        uses: dtolnay/rust-toolchain@stable
        with:
          toolchain: stable

      - name: Install Valgrind
        run: sudo apt-get update && sudo apt-get install -y valgrind

      - name: Cache cargo registry
        uses: actions/cache@v3
        with:
          path: ~/.cargo/registry
          key: ${{ runner.os }}-cargo-registry-${{ hashFiles('**/Cargo.lock') }}

      - name: Cache cargo index
        uses: actions/cache@v3
        with:
          path: ~/.cargo/git
          key: ${{ runner.os }}-cargo-git-${{ hashFiles('**/Cargo.lock') }}

      - name: Cache target directory
        uses: actions/cache@v3
        with:
          path: target
          key: ${{ runner.os }}-target-${{ hashFiles('**/Cargo.lock') }}

      - name: Run Criterion benchmarks
        run: cargo bench --workspace -- --output-format bencher | tee benchmark-output.txt

      - name: Store benchmark result
        uses: benchmark-action/github-action-benchmark@v1
        with:
          tool: 'cargo'
          output-file-path: benchmark-output.txt
          github-token: ${{ secrets.GITHUB_TOKEN }}
          auto-push: true
          # Optionally comment on PR with results
          comment-on-alert: true
          # Fail if performance regresses
          fail-on-alert: false
          alert-threshold: '150%'  # Fail if 50% slower

      - name: Run memory profiling
        run: |
          cargo test --release --package cityjson --test v2_0 test_producer_consumer_stream
          echo "Memory test completed"

      - name: Upload benchmark results
        uses: actions/upload-artifact@v3
        with:
          name: benchmark-results
          path: |
            target/criterion/
            benchmark-output.txt

  # Optional: Memory profiling job
  memory-profiling:
    name: Memory Profiling
    runs-on: ubuntu-latest
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Install Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Install Valgrind
        run: sudo apt-get update && sudo apt-get install -y valgrind

      - name: Install Just
        run: |
          curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh | bash -s -- --to /usr/local/bin

      - name: Run massif profiling
        run: just test-massif

      - name: Check memory usage
        run: |
          PEAK_MB=$(grep -E "peak" profiling/massif-report.txt | head -1 || echo "N/A")
          echo "Peak memory usage: $PEAK_MB"
          echo "peak_memory=$PEAK_MB" >> $GITHUB_OUTPUT
        id: memory

      - name: Upload profiling results
        uses: actions/upload-artifact@v3
        with:
          name: profiling-results
          path: profiling/

      - name: Comment PR with memory usage
        if: github.event_name == 'pull_request'
        uses: actions/github-script@v6
        with:
          script: |
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: '## Memory Profiling Results\n\n${{ steps.memory.outputs.peak_memory }}\n\nFull report available in artifacts.'
            })

  # Optional: Continuous benchmark tracking
  continuous-benchmark:
    name: Track Performance Over Time
    runs-on: ubuntu-latest
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Install Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Download previous benchmark data
        uses: actions/cache@v3
        with:
          path: ./bench-cache
          key: ${{ runner.os }}-benchmark-${{ github.sha }}
          restore-keys: |
            ${{ runner.os }}-benchmark-

      - name: Run benchmarks
        run: |
          if [ -f bench-cache/baseline.json ]; then
            cargo bench --workspace -- --baseline bench-cache/baseline
          fi
          cargo bench --workspace -- --save-baseline bench-cache/baseline

      - name: Store benchmark history
        uses: actions/upload-artifact@v3
        with:
          name: benchmark-history
          path: bench-cache/

  # Optional: Weekly comprehensive profiling
  weekly-profiling:
    name: Weekly Comprehensive Analysis
    runs-on: ubuntu-latest
    if: github.event_name == 'schedule'

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Install dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y valgrind
          curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh | bash -s -- --to /usr/local/bin

      - name: Install Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Run full performance suite
        run: just perf-full

      - name: Generate report
        run: |
          DATE=$(date +%Y-%m-%d)
          just bench-record "weekly-automated-$DATE"

      - name: Upload comprehensive results
        uses: actions/upload-artifact@v3
        with:
          name: weekly-profiling
          path: |
            profiling/
            target/criterion/
            bench_results/history/

# Optional: Schedule for weekly runs
# on:
#   schedule:
#     - cron: '0 0 * * 0'  # Every Sunday at midnight
