#!/usr/bin/env just --justfile

_git_ref := shell('git -C . rev-parse --short HEAD')
_profile_dir := "./profiling" / datetime("%Y-%m-%d") + "_" + _git_ref

default:
    just --list

check:
    cargo check --all-targets --all-features

build *args:
    cargo build --all-targets --all-features {{args}}

lint:
    cargo clippy --all-targets --all-features -- -Dclippy::all -Dclippy::pedantic

fmt:
    cargo fmt --all

test:
    -cargo test --all-features
    -cargo run --example cityjson_fake_complete_owned
    -cargo run --example attributes
    -cargo run --example streaming_geometry_instances

miri:
    cargo +nightly miri test --all-features

# Build and open the crate documentation
doc:
    RUSTDOCFLAGS="--cfg docsrs -Dwarnings" cargo +nightly doc --all-features --no-deps -Zunstable-options -Zrustdoc-scrape-examples

# Extract the crate signatures to target/doc/cityjson.json
doc-signatures:
    RUSTFLAGS="" RUSTDOCFLAGS="-Z unstable-options --output-format json" cargo +nightly doc --document-private-items --no-deps

# ============================================================================
# Benchmark & Profiling
# ============================================================================

# Run benchmarks and memory profiling
perf description mode="full" seed="" size="":
    ./tools/perf.sh "{{description}}" "{{mode}}" "{{seed}}" "{{size}}"

# Analyze benchmark and profiling results
perf-analyze *args:
    python3 tools/perf_analyze.py {{args}}

# ============================================================================
# Memory profiling (internal helpers used by perf)
# ============================================================================

_create_profile_dir:
    -@mkdir "{{ _profile_dir }}" > /dev/null 2>&1 || true

profile-memory-time: _create_profile_dir
    #!/usr/bin/env bash
    set -euo pipefail
    PROFILE_PKG="${PROFILE_PKG:-cityjson}"
    PROFILE_TEST="${PROFILE_TEST:-v2_0}"
    PROFILE_TEST_FILTER="${PROFILE_TEST_FILTER:-test_producer_consumer_stream}"
    PROFILE_TEST_ARGS="${PROFILE_TEST_ARGS:---test-threads=1 --nocapture}"

    OUTFILE="{{ _profile_dir }}/time.out"
    /usr/bin/time -v cargo test --package "$PROFILE_PKG" --test "$PROFILE_TEST" "$PROFILE_TEST_FILTER" --release -- $PROFILE_TEST_ARGS > "$OUTFILE" 2>&1
    cat "$OUTFILE"

profile-massif: _create_profile_dir
    #!/usr/bin/env bash
    set -euo pipefail
    PROFILE_PKG="${PROFILE_PKG:-cityjson}"
    PROFILE_TEST="${PROFILE_TEST:-v2_0}"
    PROFILE_TEST_FILTER="${PROFILE_TEST_FILTER:-test_producer_consumer_stream}"
    PROFILE_TEST_ARGS="${PROFILE_TEST_ARGS:---test-threads=1 --nocapture}"

    CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUNNER="valgrind --tool=massif --massif-out-file={{ _profile_dir }}/massif.out --time-unit=B --detailed-freq=1 --max-snapshots=200 --threshold=0.1 --log-file=/dev/null" \
        cargo test --package "$PROFILE_PKG" --test "$PROFILE_TEST" "$PROFILE_TEST_FILTER" -- $PROFILE_TEST_ARGS

    ms_print {{ _profile_dir }}/massif.out | cat > {{ _profile_dir }}/massif-report.txt

    echo "=== HEAP USAGE SUMMARY ==="
    grep -E "peak|MB|KB|snapshot" {{ _profile_dir }}/massif-report.txt | head -n 30 || true
    echo ""

    echo "=== TOP ALLOCATION SITES ==="
    grep -A 5 "% (" {{ _profile_dir }}/massif-report.txt | head -n 50 || true
    echo ""

    echo "Full report saved to {{ _profile_dir }}/massif-report.txt"
    echo "Visualize with: massif-visualizer {{ _profile_dir }}/massif.out"

profile-memcheck: _create_profile_dir
    #!/usr/bin/env bash
    set -euo pipefail
    PROFILE_PKG="${PROFILE_PKG:-cityjson}"
    PROFILE_TEST="${PROFILE_TEST:-v2_0}"
    PROFILE_TEST_FILTER="${PROFILE_TEST_FILTER:-test_producer_consumer_stream}"
    PROFILE_TEST_ARGS="${PROFILE_TEST_ARGS:---test-threads=1 --nocapture}"

    CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUNNER="valgrind --tool=memcheck --leak-check=full --show-leak-kinds=all --track-origins=yes --verbose --log-file={{ _profile_dir }}/memcheck.log" \
        cargo test --package "$PROFILE_PKG" --test "$PROFILE_TEST" "$PROFILE_TEST_FILTER" -- $PROFILE_TEST_ARGS

    echo "================================"
    echo "LEAK SUMMARY:"
    echo "================================"
    grep -A 20 "LEAK SUMMARY" {{ _profile_dir }}/memcheck.log

    echo "================================"
    echo "HEAP SUMMARY:"
    echo "================================"
    grep -A 10 "HEAP SUMMARY" {{ _profile_dir }}/memcheck.log
    echo "Full report saved to {{ _profile_dir }}/memcheck.log"

    LEAKED=$(grep "definitely lost" {{ _profile_dir }}/memcheck.log | grep -oP '\\d+(?= bytes)' | head -1 || true)
    if [ "$LEAKED" != "0" ] && [ -n "$LEAKED" ]; then
        echo "Found $LEAKED bytes definitely lost!"
        exit 1
    else
        echo "No definite memory leaks detected"
    fi

profile-cachegrind: _create_profile_dir
    #!/usr/bin/env bash
    set -euo pipefail
    PROFILE_PKG="${PROFILE_PKG:-cityjson}"
    PROFILE_TEST="${PROFILE_TEST:-v2_0}"
    PROFILE_TEST_FILTER="${PROFILE_TEST_FILTER:-test_producer_consumer_stream}"
    PROFILE_TEST_ARGS="${PROFILE_TEST_ARGS:---test-threads=1 --nocapture}"

    CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUNNER="valgrind --tool=cachegrind --cache-sim=yes --branch-sim=yes --cachegrind-out-file={{ _profile_dir }}/cachegrind.out" \
        cargo test --package "$PROFILE_PKG" --test "$PROFILE_TEST" "$PROFILE_TEST_FILTER" -- $PROFILE_TEST_ARGS

    echo "================================"
    echo "CACHE STATISTICS:"
    echo "================================"
    cg_annotate {{ _profile_dir }}/cachegrind.out | cat > {{ _profile_dir }}/cachegrind-report.txt

    head -n 50 {{ _profile_dir }}/cachegrind-report.txt

    echo "=== KEY METRICS ==="
    grep -E "I refs|D refs|LL misses|branches" {{ _profile_dir }}/cachegrind-report.txt | head -n 20 || true

    echo "Full report saved to {{ _profile_dir }}/cachegrind-report.txt"
    echo "Analyze with: kcachegrind {{ _profile_dir }}/cachegrind.out"

profile-all: profile-massif profile-cachegrind profile-memcheck

# ============================================================================
# Benchmark profiling (Valgrind over a specific benchmark)
# ============================================================================

profile-bench-massif: _create_profile_dir
    #!/usr/bin/env bash
    set -euo pipefail
    PROFILE_BENCH="${PROFILE_BENCH:-processor}"
    PROFILE_BENCH_ID="${PROFILE_BENCH_ID:-compute_full_feature_stats}"
    PROFILE_MODE="${PROFILE_MODE:-fast}"
    PROFILE_SEED="${PROFILE_SEED:-}"
    PROFILE_SIZE="${PROFILE_SIZE:-}"

    export BENCH_MODE="$PROFILE_MODE"
    if [ -n "$PROFILE_SEED" ]; then export BENCH_SEED="$PROFILE_SEED"; else unset BENCH_SEED; fi
    if [ -n "$PROFILE_SIZE" ]; then export BENCH_SIZE="$PROFILE_SIZE"; else unset BENCH_SIZE; fi
    export CARGO_TARGET_DIR="target/bench"

    bench_cmd=(cargo bench --bench "$PROFILE_BENCH")
    bench_args=()
    if [ "$PROFILE_MODE" = "fast" ]; then
        bench_args+=(--quick)
    fi
    bench_args+=(--exact "$PROFILE_BENCH_ID")

    CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUNNER="valgrind --tool=massif --massif-out-file={{ _profile_dir }}/massif.out --time-unit=B --detailed-freq=1 --max-snapshots=200 --threshold=0.1 --log-file=/dev/null" \
        "${bench_cmd[@]}" -- "${bench_args[@]}"

    ms_print {{ _profile_dir }}/massif.out | cat > {{ _profile_dir }}/massif-report.txt

    echo "=== HEAP USAGE SUMMARY ==="
    grep -E "peak|MB|KB|snapshot" {{ _profile_dir }}/massif-report.txt | head -n 30 || true
    echo ""

    echo "=== TOP ALLOCATION SITES ==="
    grep -A 5 "% (" {{ _profile_dir }}/massif-report.txt | head -n 50 || true
    echo ""

    echo "Full report saved to {{ _profile_dir }}/massif-report.txt"
    echo "Visualize with: massif-visualizer {{ _profile_dir }}/massif.out"

