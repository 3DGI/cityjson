#!/usr/bin/env just --justfile

release:
  cargo build --release    

lint:
  cargo clippy

bin:
  cargo run --bin bin -- arg1

example:
  cargo run --example exname -- arg1

# Run all tests
test:
    cargo test -- --nocapture

# Build and open the crate documentation
doc:
    RUSTDOCFLAGS="--cfg docsrs" cargo +nightly doc --all-features --no-deps -Zunstable-options -Zrustdoc-scrape-examples

test-memory-quick:
    #!/usr/bin/env bash
    echo "Running quick memory test..."
    OUTPUT=$(/usr/bin/time -v cargo test --package cityjson --test v2_0 test_producer_consumer_stream --release 2>&1)
    echo "$OUTPUT"
    MAX_MEM=$(echo "$OUTPUT" | grep "Maximum resident set size" | awk '{print $6}')
    echo "================================"
    echo "Peak RSS: ${MAX_MEM} KB ($(($MAX_MEM / 1024)) MB)"
    echo "================================"

test-massif:
    #!/usr/bin/env bash
    # Run with massif
    CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUNNER="valgrind --tool=massif --massif-out-file=./profiling/massif.out --time-unit=B --detailed-freq=1 --max-snapshots=200 --threshold=0.1 --log-file=/dev/null" \
        cargo test --package cityjson --test v2_0 test_producer_consumer_stream -- --test-threads=1 --nocapture

    # Generate readable report
    ms_print ./profiling/massif.out | cat > ./profiling/massif-report.txt

    # Extract key metrics
    echo "=== HEAP USAGE SUMMARY ==="
    grep -E "peak|MB|KB|snapshot" ./profiling/massif-report.txt | head -n 30
    echo ""

    echo "=== TOP ALLOCATION SITES ==="
    grep -A 5 "% (" ./profiling/massif-report.txt | head -n 50
    echo ""

    echo "Full report saved to ./profiling/massif-report.txt"
    echo "Visualize with: massif-visualizer ./profiling/massif.out"

test-memcheck:
    #!/usr/bin/env bash
    CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUNNER="valgrind --tool=memcheck --leak-check=full --show-leak-kinds=all --track-origins=yes --verbose --log-file=./profiling/memcheck.log" \
        cargo test --package cityjson --test v2_0 test_producer_consumer_stream -- --test-threads=1 --nocapture

    echo "================================"
    echo "LEAK SUMMARY:"
    echo "================================"
    grep -A 20 "LEAK SUMMARY" ./profiling/memcheck.log

    echo "================================"
    echo "HEAP SUMMARY:"
    echo "================================"
    grep -A 10 "HEAP SUMMARY" ./profiling/memcheck.log
    echo "Full report saved to ./profiling/memcheck.log"

    # Check for leaks
    LEAKED=$(grep "definitely lost" ./profiling/memcheck.log | grep -oP '\d+(?= bytes)' | head -1)
    if [ "$LEAKED" != "0" ] && [ -n "$LEAKED" ]; then
        echo "Found $LEAKED bytes definitely lost!"
        exit 1
    else
        echo "No definite memory leaks detected"
    fi

test-cachegrind:
    #!/usr/bin/env bash
    CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUNNER="valgrind --tool=cachegrind --cache-sim=yes --branch-sim=yes --cachegrind-out-file=./profiling/cachegrind.out" \
        cargo test --package cityjson --test v2_0 test_producer_consumer_stream -- --test-threads=1 --nocapture

    echo "================================"
    echo "CACHE STATISTICS:"
    echo "================================"
    cg_annotate ./profiling/cachegrind.out | cat > ./profiling/cachegrind-report.txt

    # Show summary
    head -n 50 ./profiling/cachegrind-report.txt

    echo "=== KEY METRICS ==="
    grep -E "I refs|D refs|LL misses|branches" ./profiling/cachegrind-report.txt | head -n 20

    echo "Full report saved to ./profiling/cachegrind-report.txt"
    echo "Analyze with: kcachegrind ./profiling/cachegrind.out"

test-analyse-all: test-massif test-cachegrind test-memcheck

test-massif-compare baseline:
    #!/usr/bin/env bash
    echo "Running new massif profile..."
    just test-massif
    echo ""

    if [ -f "{{baseline}}" ]; then
        echo "=== COMPARING WITH BASELINE ==="
        echo "Baseline: {{baseline}}"
        echo "Current:  massif.out"
        echo ""

        BASELINE_PEAK=$(grep "mem_heap_B=" {{baseline}} | awk -F= '{print $2}' | sort -n | tail -1)
        CURRENT_PEAK=$(grep "mem_heap_B=" massif.out | awk -F= '{print $2}' | sort -n | tail -1)

        echo "Baseline peak: $BASELINE_PEAK bytes ($(($BASELINE_PEAK / 1024 / 1024)) MB)"
        echo "Current peak:  $CURRENT_PEAK bytes ($(($CURRENT_PEAK / 1024 / 1024)) MB)"

        DIFF=$(($CURRENT_PEAK - $BASELINE_PEAK))
        if [ $BASELINE_PEAK -ne 0 ]; then
            PCT=$((100 * $DIFF / $BASELINE_PEAK))
        else
            PCT=0
        fi

        if [ $DIFF -gt 0 ]; then
            echo "⚠️  Memory increased by $DIFF bytes ($PCT%)"
        elif [ $DIFF -lt 0 ]; then
            echo "✓ Memory decreased by ${DIFF#-} bytes"
        else
            echo "✓ Memory unchanged"
        fi
    else
        echo "Baseline file not found. Saving current as baseline..."
        cp massif.out "{{baseline}}"
        echo "Baseline saved to {{baseline}}"
    fi

# Clean analysis artifacts
clean-analysis:
    rm -f ./profiling/massif.out ./profiling/massif-report.txt
    rm -f ./profiling/memcheck.log
    rm -f ./profiling/cachegrind.out ./profiling/cachegrind-report.txt
