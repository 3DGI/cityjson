#!/usr/bin/env just --justfile

_git_ref := shell('git -C . rev-parse --short HEAD')
_profile_dir := "./profiling" / datetime("%Y-%m-%d") + "_" + _git_ref

default:
    just --list

check:
    cargo check --all-targets --all-features

build *args:
    cargo build --all-targets --all-features {{args}}

lint:
    cargo clippy --all-targets --all-features -- -Dclippy::all -Dclippy::pedantic

fmt:
    cargo fmt --all

test:
    cargo test --all-features
    cargo run --example attributes
    cargo run --example streaming
    cargo run --example quick_start

miri:
    cargo +nightly miri test --all-features

# Build and open the crate documentation
doc:
    RUSTDOCFLAGS="--cfg docsrs -Dwarnings" cargo +nightly doc --all-features --no-deps

# Extract the crate signatures to target/doc/cityjson.json
doc-signatures:
    RUSTFLAGS="" RUSTDOCFLAGS="-Z unstable-options --output-format json" cargo +nightly doc --document-private-items --no-deps

# ============================================================================
# Benchmark & Profiling
# ============================================================================

# Run benchmarks and memory profiling
perf description mode="full" seed="" size="":
    ./tools/perf.sh "{{description}}" "{{mode}}" "{{seed}}" "{{size}}"

# Analyze benchmark and profiling results
perf-analyze *args:
    python3 tools/perf_analyze.py {{args}}

perf-check:
    cargo bench --benches --no-run

# ============================================================================
# Profiling
# ============================================================================

_create_profile_dir:
    -@mkdir "{{ _profile_dir }}" > /dev/null 2>&1 || true

# Profile a single benchmark workload (default: processor/compute_full_feature_stats)
profile-bench: _create_profile_dir
    #!/usr/bin/env bash
    set -euo pipefail
    PROFILE_BENCH="${PROFILE_BENCH:-processor}"
    PROFILE_BENCH_ID="${PROFILE_BENCH_ID:-compute_full_feature_stats}"
    PROFILE_MODE="${PROFILE_MODE:-fast}"
    PROFILE_SEED="${PROFILE_SEED:-}"
    PROFILE_SIZE="${PROFILE_SIZE:-}"
    PROFILE_TOOL="${PROFILE_TOOL:-massif}"

    export BENCH_MODE="$PROFILE_MODE"
    if [ -n "$PROFILE_SEED" ]; then export BENCH_SEED="$PROFILE_SEED"; else unset BENCH_SEED; fi
    if [ -n "$PROFILE_SIZE" ]; then export BENCH_SIZE="$PROFILE_SIZE"; else unset BENCH_SIZE; fi
    export CARGO_TARGET_DIR="target/bench"

    bench_cmd=(cargo bench --bench "$PROFILE_BENCH")
    bench_args=()
    if [ "$PROFILE_MODE" = "fast" ]; then
        bench_args+=(--quick)
    fi
    bench_args+=(--exact "$PROFILE_BENCH_ID")

    case "$PROFILE_TOOL" in
        massif)
            out="{{ _profile_dir }}/massif.out"
            report="{{ _profile_dir }}/massif-report.txt"
            CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUNNER="valgrind --tool=massif --massif-out-file=$out --time-unit=B --detailed-freq=1 --max-snapshots=200 --threshold=0.1 --log-file=/dev/null" \
                "${bench_cmd[@]}" -- "${bench_args[@]}"
            ms_print "$out" > "$report"
            echo "saved $out"
            echo "saved $report"
            ;;
        memcheck)
            log="{{ _profile_dir }}/memcheck.log"
            CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUNNER="valgrind --tool=memcheck --leak-check=full --show-leak-kinds=all --track-origins=yes --verbose --log-file=$log" \
                "${bench_cmd[@]}" -- "${bench_args[@]}"
            leaked=$(grep "definitely lost" "$log" | grep -oP '\\d+(?= bytes)' | head -1 || true)
            if [ -n "$leaked" ] && [ "$leaked" != "0" ]; then
                echo "definitely lost bytes: $leaked"
                exit 1
            fi
            echo "saved $log"
            ;;
        cachegrind)
            out="{{ _profile_dir }}/cachegrind.out"
            report="{{ _profile_dir }}/cachegrind-report.txt"
            CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUNNER="valgrind --tool=cachegrind --cache-sim=yes --branch-sim=yes --cachegrind-out-file=$out" \
                "${bench_cmd[@]}" -- "${bench_args[@]}"
            cg_annotate "$out" > "$report"
            echo "saved $out"
            echo "saved $report"
            ;;
        *)
            echo "unknown tool '$PROFILE_TOOL' (expected: massif|memcheck|cachegrind)" >&2
            exit 1
            ;;
    esac

profile-bench-massif:
    PROFILE_TOOL=massif just profile-bench

profile-bench-memcheck:
    PROFILE_TOOL=memcheck just profile-bench

profile-bench-cachegrind:
    PROFILE_TOOL=cachegrind just profile-bench

profile-bench-all:
    just profile-bench-massif
    just profile-bench-cachegrind
    just profile-bench-memcheck
