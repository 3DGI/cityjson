set dotenv-load := true
datadir := "tests" / "data" / "downloaded"

_default:
    just --list

# Create dir for downloaded files
_prepare:
    #!/usr/bin/env bash
    set -euxo pipefail
    if [ ! -d {{datadir}} ]; then
      mkdir -p {{datadir}}
    fi

# Download test data for the benchmarks from the 3DBAG
_download-3dbag: _prepare
    #!/usr/bin/env bash
    set -euxo pipefail
    version="v20231008"
    tiles=( "10-356-724" )
    download_url="https://data.3dbag.nl/"$version"/tiles"
    for tile_id in "${tiles[@]}" ;
    do
      tile_path=${tile_id//[-]//}
      tile_filename=$tile_id".city.json.gz"
      wget $download_url"/"$tile_path"/"$tile_filename -O {{datadir}}"/"$tile_filename
      gunzip {{datadir}}"/"$tile_filename
    done
    wget "https://data.3dbag.nl/"$version"/metadata.json" -O {{datadir}}"/metadata.json"

# Download test data for the benchmarks from the 3D Basivoorziening
_download-3dbasisvoorziening: _prepare
    #!/usr/bin/env bash
    set -euxo pipefail
    version="2020"
    tiles=( "30gz1" )
    download_url="https://download.pdok.nl/kadaster/basisvoorziening-3d/v1_0//"$version"/volledig"
    for tile_id in "${tiles[@]}" ;
    do
      tile_filename=$tile_id"_"$version"_volledig.zip"
      wget $download_url"/"$tile_filename -O {{datadir}}"/"$tile_filename
      unzip {{datadir}}"/"$tile_filename -d {{datadir}}
      rm {{datadir}}"/"$tile_filename
    done

# Upgrade downloaded CityJSON files from v1.1 to v2.0
_upgrade:
    uvx cjio@0.10.1 {{datadir}}/10-356-724.city.json upgrade save {{datadir}}/10-356-724.city.json
    uvx cjio@0.10.1 {{datadir}}/30gz1_04.city.json upgrade save {{datadir}}/30gz1_04.city.json

# Download test data for the benchmarks
download: _download-3dbag _download-3dbasisvoorziening _upgrade

# Delete all downloaded files
clean:
    rm -rf {{datadir}}

# Run all benchmarks and generate the comparison plots. Requires a python virtualenv in "resources/compare_benchmarks/.venv"
bench: bench-read bench-write bench-plot

bench-read:
    cargo bench --bench read --

bench-write:
    cargo bench --bench write --

bench-plot:
    uv run resources/compare_benchmarks/compare_benchmarks.py

bench-report:
    uv run resources/compare_benchmarks/compare_benchmarks.py --markdown

synthetic-bench-specs:
    @printf '%s\n' \
      'Synthetic benchmark profiles:' \
      '  README: tests/data/generated/README.md' \
      '  manifest: tests/data/generated/manifest.json' \
      '' \
      'These are benchmark profiles. cjfake generates the inputs at benchmark time.'

synthetic-bench-manifest:
    cat tests/data/generated/manifest.json

synthetic-bench-readme:
    cat tests/data/generated/README.md

check:
    cargo check --all-targets --all-features

build *args:
    cargo build --all-targets --all-features {{args}}

lint:
    cargo clippy --all-targets --all-features -- -Dclippy::all -Dclippy::pedantic

fmt:
    cargo fmt --all

test:
    cargo test --lib --tests --all-features

doc:
    cargo doc --all-features --no-deps --open
