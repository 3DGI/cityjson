{
  "type": "CityJSONExtension",
  "name": "Noise",
  "description": "Extension to model the noise",
  "url": "https://someurl.org/noise.ext.json",
  "version": "0.5",
  "versionCityJSON": "1.1",
  "extraRootProperties": {},
  "extraAttributes": {},
	"extraCityObjects": {
		"+NoiseBuilding": {
			"allOf": [
				{ "$ref": "cityobjects.schema.json#/_AbstractBuilding" },
				{
					"properties": {
						"type": { "enum": ["+NoiseBuilding"] },
						"attributes": {
							"properties": {
								"buildingLDenMin": {"type": "number"}
							}
						}
					},
					"required": ["type"]
				}
			]
		}
	}
}