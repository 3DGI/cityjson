#!/usr/bin/env just --justfile

_default:
    just --list

check:
    cargo check --all-targets --all-features

build *args:
    cargo build --all-targets --all-features {{args}}

lint:
    cargo clippy --all-targets --all-features -- -Dclippy::all -Dclippy::pedantic

fmt:
    cargo fmt --all

test:
    cargo test --workspace --all-features --no-fail-fast

# Build the crate documentation
doc:
    RUSTDOCFLAGS="--cfg docsrs -Dwarnings" cargo doc --all-features --no-deps

# Build the MkDocs Material site
docs-build:
    python3 -m mkdocs build --strict

# Serve the MkDocs Material site locally
docs-serve:
    python3 -m mkdocs serve
