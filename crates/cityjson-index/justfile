#!/usr/bin/env just --justfile

_default:
    just --list

# Build the shared FFI core crate.
ffi-build:
    cargo build --manifest-path ffi/core/Cargo.toml --release --lib

# Run the shared FFI core crate tests.
ffi-test:
    cargo test --manifest-path ffi/core/Cargo.toml --all-features

# Run the shared FFI validation pipeline.
ffi:
    just ffi-build
    just ffi-test

# Prepare the local bootstrap corpus from the pinned 3DBAG data set.
prep-test-data:
    cargo run --release --features dev-binaries --bin prep-test-data -- --skip-cjval

# Prepare the minimal corpus needed for CI and release validation.
prep-test-data-ci:
    cargo run --release --features dev-binaries --bin prep-test-data -- --skip-cjval --max-tiles 1

# Fast compile-time validation across all targets and features.
check:
    cargo check --all-targets --all-features

# Build all targets with all features enabled.
build *args:
    cargo build --all-targets --all-features {{args}}

clean:
    cargo clean
    rm -rf ffi/python/dist ffi/python/build
    

# Run clippy with the project's strict lint settings.
lint:
    cargo clippy --all-targets --all-features -- -Dclippy::all -Dclippy::pedantic

# Format the workspace with rustfmt.
fmt:
    cargo fmt --all

# Run the library and integration tests with all features enabled.
test:
    cargo test --lib --tests --all-features

# Build the shared library and run the Python install smoke tests through tox and tox-uv.
test-python:
    cargo build --manifest-path ffi/core/Cargo.toml --release --lib
    sh -c 'tmpdir=$(mktemp -d); cd ../cityjson-lib/ffi/python && uv build --wheel --out-dir "$tmpdir" && cd ../../../cityjson-index/ffi/python && UV_FIND_LINKS="$tmpdir" uv run tox run'

# Build API docs for all features without pulling in dependencies.
doc:
    cargo doc --all-features --no-deps

# Benchmark the feature-files backend in the default bench profile.
bench-feature-files:
    cargo bench --bench feature_files

# Benchmark the CityJSON backend in the default bench profile.
bench-cityjson:
    cargo bench --bench cityjson

# Benchmark the NDJSON backend in the default bench profile.
bench-ndjson:
    cargo bench --bench ndjson

# Build the Python bindings wheel.
build-python:
    uv build ffi/python/ --wheel --out-dir ffi/python/dist

# Run the investigation binary and the release-mode benchmarks used for reporting.
bench-release:
    cargo run --release --features dev-binaries --bin investigate-read-performance
    cargo bench --bench cityjson
    cargo bench --bench feature_files --bench ndjson

# Run the release-quality validation pipeline.
ci:
    just fmt
    just check
    just lint
    just prep-test-data-ci
    just test
    just ffi
    just test-python
    just doc
