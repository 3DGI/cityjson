#!/usr/bin/env just --justfile

default:
    just --list

prep-test-data:
    cargo run -- prep-test-data

prep-feature-files:
    cargo run -- prep-test-data --layout feature-files

prep-cityjson:
    cargo run -- prep-test-data --layout cityjson

prep-ndjson:
    cargo run -- prep-test-data --layout ndjson

check:
    cargo check --all-targets --all-features

build *args:
    cargo build --all-targets --all-features {{args}}

lint:
    cargo clippy --all-targets --all-features -- -Dclippy::all -Dclippy::pedantic

fmt:
    cargo fmt --all

test:
    cargo test --all-features

bench-feature-files:
    cargo bench --bench feature_files

bench-cityjson:
    cargo bench --bench cityjson

bench-ndjson:
    cargo bench --bench ndjson
